// Copy this file to APIKeys.swift (gitignored) and fill in your keys.
// Anthropic key:  https://console.anthropic.com
// ElevenLabs key: https://elevenlabs.io  →  Profile → API Key
// Supabase:      https://supabase.com/dashboard → your project → Settings → API
//   Use the **Project URL** and **anon public** key (same project for both).
enum APIKeys {
    static let anthropic = "sk-ant-..."

    // ElevenLabs — used for Pepper's spoken voice (TTS).
    static let elevenLabs = "sk_..."
    static let elevenLabsVoiceId = "..."  // Voice ID from elevenlabs.io → Voices

    /// Must be a live `https://<ref>.supabase.co` URL (verify in a browser). Replace placeholders.
    static let supabaseURL = "https://YOUR_PROJECT_REF.supabase.co"
    static let supabaseAnonKey = "YOUR_ANON_KEY"
    // Auth: add redirect URL `pepper://auth-callback` in Supabase → Authentication → URL Configuration.
    // Then enable Google and Apple under Authentication → Providers. Both must be enabled for social sign-in.
}
